# Stock Investment Agent - 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# ==================== API Keys ====================

# DeepSeek API Key（在线模式必需）
# 获取方式：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ==================== 飞书配置 ====================

# 飞书推送配置
# 获取方式：飞书开放平台 -> 我的应用 -> 获取 User Open ID
FEISHU_USER_OPEN_ID=your_feishu_user_open_id_here

# ==================== 部署配置 ====================

# Cloudflare Pages 项目名（可选，默认 stock-morning-brief）
CF_PAGES_PROJECT=stock-morning-brief

# ==================== 运行环境 ====================

# 运行环境（development/production）
# STOCK_SKILLS_ENV=development

# 日志级别（DEBUG/INFO/WARNING/ERROR）
# STOCK_SKILLS_LOG_LEVEL=INFO
